  <!-- 末端执行器 -->
  <joint name="joint_tcp" type="fixed">
    <parent link="Link8" />
    <child link="tcp" />
    <origin xyz="0 0 0.05" rpy="0 0 0" />
  </joint>

  <link name="tcp">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
